# Satellite Cloud Clear AI - Environment Variables
# Copy to .env and modify as needed

# Server
HOST=0.0.0.0
PORT=8000
DEBUG=false

# Paths
UPLOAD_DIR=./uploads
OUTPUT_DIR=./outputs
TEMP_DIR=./temp

# Upload limits
MAX_UPLOAD_SIZE_MB=500

# Model
MODEL_NAME=placeholder
CHECKPOINT_PATH=
MODEL_DEVICE=cpu

# CORS
CORS_ORIGINS=*
